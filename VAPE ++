local function fistsEquipped()

    local live = workspace:FindFirstChild("Live")
    if not live then return false end

    local myModel = live:FindFirstChild(LocalPlayer.Name)
    if not myModel then return false end

    return myModel:FindFirstChild("Fight") ~= nil

end

-- =========================
-- AUTO WEAVE
-- =========================
local AutoWeaveConnection
local AutoWeave = false
local WeaveDelay = 0.2

local AutoWeaveSection = CombatTab:NewSection("Auto Weave")

CombatTab:NewLabel("Auto Weave","left")

CombatTab:NewToggle("Auto Weave",false,function(state)

    AutoWeave = state

    if AutoWeaveConnection then
        AutoWeaveConnection:Disconnect()
        AutoWeaveConnection = nil
    end

    if not state then return end

local elapsed = 0
local weaveRemote

AutoWeaveConnection = RunService.Heartbeat:Connect(function(dt)

    if not AutoWeave then return end
    if not fistsEquipped() then return end

    local char = LocalPlayer.Character
    if not char then return end

    -- only find remote once
    if not weaveRemote then
        local core = char:FindFirstChild("Core")
        if not core then return end

        local comm = core:FindFirstChild("Communicate")
        if not comm then return end

        for _,v in pairs(comm:GetChildren()) do
            if v:IsA("RemoteEvent") then
                weaveRemote = v
                break
            end
        end

        if not weaveRemote then return end

        if not fistsEquipped() then
            weaveRemote = nil
            return
        end
    end

    elapsed += dt

    -- micro variation to avoid perfect timing
    local interval = WeaveDelay + (math.random() - 0.5) * 0.00005

    if elapsed >= interval then
        elapsed = 0

        local RemoteArgs = {"Weave", nil, true}

        pcall(function()
        weaveRemote:FireServer(unpack(RemoteArgs))
            task.wait(2)
            weaveRemote:FireServer(unpack(RemoteArgs))
        end)


    end

end)
end)


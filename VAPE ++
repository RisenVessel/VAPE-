local originalHRPProps = {}

local function resetHRP(targetPlayer)

    local props = originalHRPProps[targetPlayer]

    if props and targetPlayer.Character then

        local Root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")

        if Root then

            Root.Size = props.Size
            Root.Transparency = props.Transparency
            Root.CanCollide = props.CanCollide
            Root.Color = props.Color
            Root.CanTouch = false
            Root.CanQuery = false

        end
    end
end

local function updateHitbox(targetPlayer)

	if targetPlayer == LocalPlayer then return end
	if not targetPlayer.Character then return end

	local Root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
	local Hum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")

	if not Root or not Hum then return end

	local liveFolder = workspace:FindFirstChild("Live")
	local entry = liveFolder and liveFolder:FindFirstChild(targetPlayer.Name)

	local isKnocked =
	(entry and entry:FindFirstChild("Knocked") and entry.Knocked.Value == true)
	or Hum.Health <= 0
    or Hum.PlatformStand

	if isKnocked then
    if not RagerMode then
        resetHRP(targetPlayer)
        return
    end
end

	if HitboxEnabled then

		if not originalHRPProps[targetPlayer] then

			originalHRPProps[targetPlayer] = {
				Size = Root.Size,
				Transparency = Root.Transparency,
				CanCollide = Root.CanCollide,
				Color = Root.Color
			}

		end


		Root.Size = Vector3.new(TargetHitboxSize, TargetHitboxSize, TargetHitboxSize)
		Root.Transparency = HitboxTransparency
		Root.Material = Enum.Material.SmoothPlastic
		Root.Color = Color3.fromRGB(0,0,0)
		Root.CanCollide = false
        Root.CastShadow = false
        Root.CanQuery = true
        Root.CanTouch = false
        Root.AssemblyLinearVelocity = Vector3.zero
        Root.AssemblyAngularVelocity = Vector3.zero
        Root.CustomPhysicalProperties = PhysicalProperties.new(0,0,0,0,0)

        pcall(function()
    Root:SetNetworkOwner(LocalPlayer)
end)



	else
		resetHRP(targetPlayer)
        originalHRPProps[targetPlayer] = nil
        Root.Material = Enum.Material.Plastic
        Root.CanQuery = false
	end

end


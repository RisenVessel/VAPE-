local punchIDs = {
    ["18312333191"] = true, 
    ["18312335714"] = true,
    ["18312338197"] = true, 
    ["18312340119"] = true,
    ["18312344029"] = true, 
    ["18312346524"] = true,
    ["18312348771"] = true,
    ["18312351760"] = true
}

local function safePunch(fn) pcall(fn) end

local function isPunch(track)
    if not track or not track.Animation then return false end
    if track.Priority == Enum.AnimationPriority.Core or 
       track.Priority == Enum.AnimationPriority.Idle or 
       track.Priority == Enum.AnimationPriority.Movement then return false end
       
    local id = track.Animation.AnimationId:match("%d+")
    if punchIDs[id] then return true end
    
    local name = track.Name:lower()
    return (name:find("punch") or name:find("swing") or name:find("attack")) and not name:find("walk") and not name:find("run")
end

local function punchDisconnectKey(key)
    local c = punchConnCache[key]
    if c and c.Disconnect then pcall(function() c:Disconnect() end) end
    punchConnCache[key] = nil
end

local function findLocalLive()
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    local myModel = live:FindFirstChild(LocalPlayer.Name)
    if not myModel then return nil end
    local hum = myModel:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    local anim = hum:FindFirstChildOfClass("Animator")
    return myModel, hum, anim
end

applyPunchSpeedToLocalLive = function(mult)
    -- Update global variable so it remembers what we set
    if mult then currentPunchSpeed = mult end
    
    local myModel, hum, anim = findLocalLive()
    
    if not myModel then return end
    
    -- Adjust currently playing tracks
if anim then
    for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
        if isPunch(t) then
            safePunch(function()
                t:AdjustSpeed(currentPunchSpeed)
            end)
        end
    end
end
    
    -- Hook Humanoid (Secondary check)
    if hum then
        punchDisconnectKey(hum)
        punchConnCache[hum] = hum.AnimationPlayed:Connect(function(t)
            if isPunch(t) then safePunch(function() t:AdjustSpeed(currentPunchSpeed) end) end
        end)
    end
end

-- RESPAWN MONITOR: This ensures speed persists after death
local function startRespawnMonitor()
    local function hookLiveFolder(folder)
        folder.ChildAdded:Connect(function(child)
            -- If the new child is ME (The Player)
            if child.Name == LocalPlayer.Name then
                -- Wait a split second for the Animator to load, then re-apply speed
                task.wait(0.5)
                applyPunchSpeedToLocalLive(currentPunchSpeed)
            end
        end)
    end

    local existingLive = workspace:FindFirstChild("Live")
    if existingLive then hookLiveFolder(existingLive) end

    -- Watch for map resets (Live folder recreation)
    workspace.ChildAdded:Connect(function(c)
        if c.Name == "Live" then
            hookLiveFolder(c)
        end
    end)
end

task.spawn(startRespawnMonitor)
task.spawn(function() applyPunchSpeedToLocalLive(currentPunchSpeed) end)


-- =========================
-- SCRIPT DETECTION SYSTEM
-- =========================

local ScriptDetectEnabled = true

local flaggedPlayers = {}
local lastWalkSpeed = {}

local function notifyOnce(plr,msg)

    if flaggedPlayers[plr] then return end
    flaggedPlayers[plr] = true

    Notif:Notify(plr.Name.." "..msg,6,"warning")

end


local function monitorPlayer(plr)

    if plr == LocalPlayer then return end

    plr.CharacterAdded:Connect(function(char)

        local hum = char:WaitForChild("Humanoid",10)
        local root = char:WaitForChild("HumanoidRootPart",10)

        if not hum or not root then return end

        -- WALK SPEED DETECTION
        hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()

            if not ScriptDetectEnabled then return end

            local speed = hum.WalkSpeed
            local live = workspace:FindFirstChild("Live")
            local entry = live and live:FindFirstChild(plr.Name)

            local sprinting = false

            if entry and entry:FindFirstChild("Sprint") then
                sprinting = entry.Sprint.Value
            end

            if speed > 10 and not sprinting then

                if lastWalkSpeed[plr] ~= speed then

                    Notif:Notify(plr.Name.." may be using WalkSpeed ("..speed..")",6,"warning")
                    lastWalkSpeed[plr] = speed

                end

            end

        end)

        -- HITBOX DETECTION
        task.spawn(function()

            while char.Parent do
                task.wait(1)

                if not ScriptDetectEnabled then continue end

                if root.Size.X > 3 then
                    notifyOnce(plr,"may be using Hitbox Expander")
                end

            end

        end)

        -- ANTI STUN DETECTION
        char.ChildRemoved:Connect(function(obj)

            if not ScriptDetectEnabled then return end

            if obj.Name == "WeaveStun" then
                notifyOnce(plr,"may be using Anti-Stun")
            end

        end)
        

    end)

end


-- Monitor existing players
for _,plr in pairs(Players:GetPlayers()) do
    monitorPlayer(plr)
    monitorPunchSpeed(plr)
end

-- Monitor players joining
Players.PlayerAdded:Connect(function(plr)
    monitorPlayer(plr)
    monitorPunchSpeed(plr)
end)


